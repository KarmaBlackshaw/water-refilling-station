{
  "permissions": {
    "allow": ["Bash(npx skills *)", "mcp__lean-ctx__ctx_read", "mcp__lean-ctx__ctx_search", "mcp__lean-ctx__ctx_tree", "mcp__lean-ctx__ctx_shell"]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"/Users/admin/.claude/plugins/cache/caveman/caveman/63e797cd753b/hooks/caveman-statusline.sh\""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-generated.sh\"",
            "statusMessage": "Guarding generated files"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/eslint-fix.sh\"",
            "statusMessage": "eslint --fix"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/forbidden-patterns.sh\"",
            "statusMessage": "Checking axi conventions"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/recall-memory.sh\" SessionStart",
            "statusMessage": "Loading repo memory"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '%s' '{\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":\"REPO RULE: before responding, invoke these skills via the Skill tool, in order: using-superpowers, dispatching-parallel-agents, vue-best-practices, web-component-design, vue-pinia-best-practices. Skip an invocation only if that skill is already loaded this session.\"}}'",
            "statusMessage": "Loading repo skills"
          }
        ]
      }
    ]
  }
}
