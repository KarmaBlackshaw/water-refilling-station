{
  "$schema": "https://json.schemastore.org/prettierrc",
  "tailwindConfig": "./tailwind.config.js",
  "arrowParens": "always",
  "bracketSameLine": false,
  "endOfLine": "auto",
  "insertPragma": false,
  "jsxBracketSameLine": false,
  "jsxSingleQuote": false,
  "printWidth": 160,
  "proseWrap": "preserve",
  "requirePragma": false,
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "es5",
  "useTabs": false
}
