VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_KEY=your-supabase-publishable-key
# For scripts/onboard-admin.mjs only — never commit, never expose to frontend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Superadmin (platform admin) login — a frontend env gate, NOT a Supabase user.
# These VITE_ vars ship in the bundle, so anyone can read them: treat as
# convenience gating only and use a strong, unique password.
VITE_SUPERADMIN_EMAIL=superadmin@example.com
VITE_SUPERADMIN_PASSWORD=set-a-strong-password
