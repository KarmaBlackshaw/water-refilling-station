{
  "name": "water-refilling-station",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "lint:theme": "! grep -rEn '(bg-white|bg-gray-(50|100|200|300|400)|border-lightgray|text-dark|text-neutral)' src --include='*.vue'",
    "format": "prettier --write --experimental-cli src/",
    "db:types": "supabase gen types typescript --linked --schema public > src/types/database/supabase.ts && eslint src/types/database/supabase.ts --fix",
    "onboard": "node scripts/onboard-admin.mjs"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@mapbox/mapbox-sdk": "^0.16.2",
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tiptap/extension-placeholder": "^2.10.4",
    "@tiptap/extension-underline": "^2.10.4",
    "@tiptap/pm": "^2.10.4",
    "@tiptap/starter-kit": "^2.10.4",
    "@tiptap/vue-3": "^2.10.4",
    "@types/lodash": "^4.17.24",
    "@vuepic/vue-datepicker": "^12.1.0",
    "@vueuse/core": "^14.2.1",
    "@vueuse/router": "^14.2.1",
    "browser-image-compression": "^2.0.2",
    "chart.js": "^4.5.1",
    "dayjs": "^1.11.19",
    "globals": "^17.4.0",
    "jspdf": "^4.2.0",
    "lodash": "^4.17.23",
    "mapbox-gl": "^3.24.0",
    "pinia": "^3.0.4",
    "sass": "^1.97.3",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.29",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.0.7",
    "vue-tailwind-datepicker": "^1.7.4",
    "vue-toastification": "^2.0.0-rc.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/mapbox__mapbox-sdk": "^0.16.5",
    "@types/node": "^24.11.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.50.0",
    "eslint-plugin-vue": "~10.8.0",
    "fast-glob": "^3.3.3",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.8.1",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
